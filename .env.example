# =============================================================================
#  RINL Vizag Steel — Centralized Delay Analysis System
#  Environment variables (copy to .env and fill real values)
# =============================================================================

# ── Client-safe (VITE_* — bundled into the browser) ─────────────────────────

# Supabase project URL — from Project Settings > API
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase anon / publishable key — from Project Settings > API
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key>"

# Supabase project ref — the <project-ref> segment from the URL above
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# ── Server-only (process.env — NEVER reach the browser) ─────────────────────

# Same Supabase URL — needed server-side for admin client and auth middleware
SUPABASE_URL="https://<project-ref>.supabase.co"

# Same anon/key — needed server-side for auth middleware
SUPABASE_PUBLISHABLE_KEY="<anon-key>"

# Service-role key — from Project Settings > API (KEEP SECRET — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Shared secret to protect the /api/public/seed endpoint (any string you choose)
SEED_SECRET="<your-seed-secret>"

# Public site URL (used in sitemap.xml and social meta tags)
SITE_URL="https://<your-production-domain>"
